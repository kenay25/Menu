# ─────────────────────────────────────────────────────────────
# La Esquina del Sushi — Variables de Entorno
# ─────────────────────────────────────────────────────────────

# Base de datos
DATABASE_URL=mysql+pymysql://usuario:password@host:3306/database

# JWT - Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=tu_clave_secreta_muy_larga_y_segura_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin inicial
ADMIN_EMAIL=admin@laesquinadelsushi.com
ADMIN_PASSWORD=tu_contraseña_segura_aqui
ADMIN_NOMBRE=Kenay

# Backups
BACKUP_DIR=backups
MAX_BACKUPS=5
BACKUP_HORA=2

# App
APP_ENV=production

# CORS - Dominios permitidos (separados por coma)
CORS_ORIGINS=https://laesquinadelsushi.vercel.app

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_LOGIN_PER_MINUTE=5
